<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_OrderRouting" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/order-routing">
  <bpmn:process id="Process_OrderRouting" name="Order Routing" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="Var_Amount" name="amount" type="number" />
      </uipath:variables>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Order">
      <bpmn:outgoing>Flow_Start_Gw</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gw_Value" name="Value check" default="Flow_Standard">
      <bpmn:incoming>Flow_Start_Gw</bpmn:incoming>
      <bpmn:outgoing>Flow_HighValue</bpmn:outgoing>
      <bpmn:outgoing>Flow_Standard</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_HighValue" name="High-value handling">
      <bpmn:incoming>Flow_HighValue</bpmn:incoming>
      <bpmn:outgoing>Flow_High_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Standard" name="Standard handling">
      <bpmn:incoming>Flow_Standard</bpmn:incoming>
      <bpmn:outgoing>Flow_Std_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Order">
      <bpmn:incoming>Flow_High_End</bpmn:incoming>
      <bpmn:incoming>Flow_Std_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Gw" sourceRef="Start_Order" targetRef="Gw_Value" />
    <bpmn:sequenceFlow id="Flow_HighValue" sourceRef="Gw_Value" targetRef="Task_HighValue">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.amount &gt; 5000</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Standard" sourceRef="Gw_Value" targetRef="Task_Standard" />
    <bpmn:sequenceFlow id="Flow_High_End" sourceRef="Task_HighValue" targetRef="End_Order" />
    <bpmn:sequenceFlow id="Flow_Std_End" sourceRef="Task_Standard" targetRef="End_Order" />
  </bpmn:process>
</bpmn:definitions>
