    {
      "match": "or folders list --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"5a8b9c2d-1e3f-4a6b-8c9d-0e1f2a3b4c5d\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-5a8b9c2d-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key 5a8b9c2d-1e3f-4a6b-8c9d-0e1f2a3b4c5d --state Faulted --output json",
      "file": "or-jobs-list-folder-key-5a8b9c2d-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"7f3e2a1b-9c8d-4e5f-a6b7-c8d9e0f1a2b3\" --output json",
      "file": "or-jobs-get-7f3e2a1b-output-json.json"
    },
    {
      "match": "or jobs get 7f3e2a1b-9c8d-4e5f-a6b7-c8d9e0f1a2b3 --output json",
      "file": "or-jobs-get-7f3e2a1b-output-json.json"
    },
    {
      "match": "or jobs logs \"7f3e2a1b-9c8d-4e5f-a6b7-c8d9e0f1a2b3\" --level Error --output json",
      "file": "or-jobs-logs-7f3e2a1b-level-error-output-json.json"
    },
    {
      "match": "or jobs logs 7f3e2a1b-9c8d-4e5f-a6b7-c8d9e0f1a2b3 --level Error --output json",
      "file": "or-jobs-logs-7f3e2a1b-level-error-output-json.json"
    },
    {
      "match": "or assets list --folder-key 5a8b9c2d-1e3f-4a6b-8c9d-0e1f2a3b4c5d --output json",
      "file": "or-assets-list-folder-key-5a8b9c2d-output-json.json"
    },
    {
      "match": "or assets list --folder-key \"5a8b9c2d-1e3f-4a6b-8c9d-0e1f2a3b4c5d\" --output json",
      "file": "or-assets-list-folder-key-5a8b9c2d-output-json.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Proxy open-ended docsai queries to the real uip CLI; cache results in _cache/."
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: any uip command not matched returns []. Lets the agent explore beyond the recorded path."
  }
