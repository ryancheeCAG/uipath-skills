{
  "version": 2,
  "_doc": "Synthetic fixture set for the foreground-misconfigured cause-branch. Failing job is MisconfiguredForeground (d1e2f3a4-...); blocking foreground job is ForegroundHolder (e1f2a3b4-...). The agent must inspect process/Main.xaml + process/project.json to identify the misconfig (no UI activities, yet requiresUserInteraction=true).",
  "rules": [
    {
      "match": "or folders list-current-user --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"b2c3d4e5-f6a7-8901-2345-6789abcdef01\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-b2c3d4e5-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key b2c3d4e5-f6a7-8901-2345-6789abcdef01 --state Faulted --output json",
      "file": "or-jobs-list-folder-key-b2c3d4e5-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"b2c3d4e5-f6a7-8901-2345-6789abcdef01\" --output json",
      "file": "or-jobs-list-folder-key-b2c3d4e5-output-json.json"
    },
    {
      "match": "or jobs list --folder-key b2c3d4e5-f6a7-8901-2345-6789abcdef01 --output json",
      "file": "or-jobs-list-folder-key-b2c3d4e5-output-json.json"
    },
    {
      "match": "or jobs get \"d1e2f3a4-b5c6-4789-abcd-ef0123456789\" --output json",
      "file": "or-jobs-get-d1e2f3a4-output-json.json"
    },
    {
      "match": "or jobs get d1e2f3a4-b5c6-4789-abcd-ef0123456789 --output json",
      "file": "or-jobs-get-d1e2f3a4-output-json.json"
    },
    {
      "match": "or jobs get \"e1f2a3b4-c5d6-4789-abcd-ef0123456789\" --output json",
      "file": "or-jobs-get-e1f2a3b4-output-json.json"
    },
    {
      "match": "or jobs get e1f2a3b4-c5d6-4789-abcd-ef0123456789 --output json",
      "file": "or-jobs-get-e1f2a3b4-output-json.json"
    },
    {
      "match": "or jobs logs \"d1e2f3a4-b5c6-4789-abcd-ef0123456789\" --level Error --output json",
      "file": "or-jobs-logs-d1e2f3a4-level-error-output-json.json"
    },
    {
      "match": "or jobs logs d1e2f3a4-b5c6-4789-abcd-ef0123456789 --level Error --output json",
      "file": "or-jobs-logs-d1e2f3a4-level-error-output-json.json"
    },
    {
      "match": "or jobs logs \"d1e2f3a4-b5c6-4789-abcd-ef0123456789\" --output json",
      "file": "or-jobs-logs-d1e2f3a4-output-json.json"
    },
    {
      "match": "or jobs logs d1e2f3a4-b5c6-4789-abcd-ef0123456789 --output json",
      "file": "or-jobs-logs-d1e2f3a4-output-json.json"
    },
    {
      "match": "or robots list --folder-key \"b2c3d4e5-f6a7-8901-2345-6789abcdef01\" --output json",
      "file": "or-robots-list-folder-key-b2c3d4e5-output-json.json"
    },
    {
      "match": "or robots list --folder-key b2c3d4e5-f6a7-8901-2345-6789abcdef01 --output json",
      "file": "or-robots-list-folder-key-b2c3d4e5-output-json.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Proxy any docsai query to the real uip CLI; cache results in _cache/."
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: unmatched uip commands return an empty array."
  }
}
