{
  "Name": "WordContractStamp",
  "ProjectType": "Process",
  "Description": "Repro: Word Add Picture process whose XAML is correct (WordAddImage properly nested in UseWordFile, valid absolute ImagePath) but faults at runtime with COM HRESULT 0x8002801D (TYPE_E_LIBNOTREGISTERED) because the Word interop type library is not registered on the robot host. Environmental fault, not a source defect. Exercises the type-library-not-registered branch (E1) of the word-com-interop-failures playbook (reached via add-picture-failures.md C2, which delegates to it).",
  "MainFile": "Main.xaml"
}
