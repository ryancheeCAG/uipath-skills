  <Sequence DisplayName="Main Sequence" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="sd:DataTable" Name="salesData" />
    </Sequence.Variables>
    <ui:LogMessage DisplayName="Log: starting Excel import" sap2010:WorkflowViewState.IdRef="LogMessage_1" Level="Info" Message="[&quot;[ExcelDailyImport] Starting daily sales import — reading C:\Robot\Data\sales-2026-05.xlsx&quot;]" />
    <uix:ExcelApplicationScope DisplayName="Use Excel File: sales-2026-05.xlsx" WorkbookPath="C:\Robot\Data\sales-2026-05.xlsx" Visible="False" sap2010:WorkflowViewState.IdRef="ExcelApplicationScope_1">
      <uix:ExcelApplicationScope.Body>
        <ActivityAction x:TypeArguments="uix:WorkbookApplication">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="uix:WorkbookApplication" Name="ExcelWorkbookScope" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Body" sap2010:WorkflowViewState.IdRef="Sequence_2">
            <uix:ExcelReadRange DisplayName="Read Range: Sheet1!A1" SheetName="Sheet1" Range="" DataTable="[salesData]" sap2010:WorkflowViewState.IdRef="ExcelReadRange_1" />
            <ui:LogMessage DisplayName="Log: rows imported" sap2010:WorkflowViewState.IdRef="LogMessage_2" Level="Info" Message="[String.Format(&quot;[ExcelDailyImport] Imported {0} rows.&quot;, salesData.Rows.Count)]" />
          </Sequence>
        </ActivityAction>
      </uix:ExcelApplicationScope.Body>
    </uix:ExcelApplicationScope>
    <ui:LogMessage DisplayName="Log: import complete" sap2010:WorkflowViewState.IdRef="LogMessage_3" Level="Info" Message="[&quot;[ExcelDailyImport] Import complete.&quot;]" />
  </Sequence>
