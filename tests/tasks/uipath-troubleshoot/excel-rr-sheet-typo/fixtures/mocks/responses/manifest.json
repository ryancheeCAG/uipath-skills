{
  "version": 2,
  "_doc": "Synthetic fixture set for the typo branch of the excel-activities/read-range-sheet-not-found playbook. Agent must chain: folders list-current-user → jobs list --state Faulted → jobs get → jobs logs (reveals the enumerated sheet list ['Sheet1', 'Data', 'Summary'] from the prior Get Workbook Sheets activity) → workflow source. Compare configured 'Datab' against actual 'Data' to identify the typo.",
  "rules": [
    {
      "match": "or folders list-current-user --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"f0011111-2222-3333-4444-555566667777\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f0011111-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key f0011111-2222-3333-4444-555566667777 --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f0011111-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"aa111111-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-get-aa111177-output-json.json"
    },
    {
      "match": "or jobs get aa111111-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-get-aa111177-output-json.json"
    },
    {
      "match": "or jobs history \"aa111111-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-history-aa111177-output-json.json"
    },
    {
      "match": "or jobs history aa111111-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-history-aa111177-output-json.json"
    },
    {
      "match": "or jobs logs \"aa111111-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-logs-aa111177-output-json.json"
    },
    {
      "match": "or jobs logs aa111111-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-logs-aa111177-output-json.json"
    }
  ]
}
