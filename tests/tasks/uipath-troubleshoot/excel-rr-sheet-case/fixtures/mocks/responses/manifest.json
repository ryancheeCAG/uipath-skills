    {
      "match": "or folders list-current-user --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"f0011111-2222-3333-4444-555566667777\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f0011111-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key f0011111-2222-3333-4444-555566667777 --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f0011111-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"bb222222-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-get-bb222277-output-json.json"
    },
    {
      "match": "or jobs get bb222222-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-get-bb222277-output-json.json"
    },
    {
      "match": "or jobs history \"bb222222-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-history-bb222277-output-json.json"
    },
    {
      "match": "or jobs history bb222222-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-history-bb222277-output-json.json"
    },
    {
      "match": "or jobs logs \"bb222222-7777-8888-9999-000011112222\" --output json",
      "file": "or-jobs-logs-bb222277-output-json.json"
    },
    {
      "match": "or jobs logs bb222222-7777-8888-9999-000011112222 --output json",
      "file": "or-jobs-logs-bb222277-output-json.json"
    }
  ]
}
