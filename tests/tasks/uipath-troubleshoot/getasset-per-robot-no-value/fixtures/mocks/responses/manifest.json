{
  "version": 2,
  "_doc": "Synthetic fixtures hand-authored from the get-asset-per-robot-no-value playbook signature. Replace with verbatim captures from a real .local/investigations/ before treating as a regression signal (see ../_shared/scripts/generate_scenario.py).",
  "rules": [
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-current-user-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"2c5e8f4a-9b3d-4f6c-8e1d-7a2b3c4d5e6f\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-2c5e8f4a-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key 2c5e8f4a-9b3d-4f6c-8e1d-7a2b3c4d5e6f --state Faulted --output json",
      "file": "or-jobs-list-folder-key-2c5e8f4a-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"4d7e9f3a-1b6c-5e8f-9d4c-3b2a1f0e9d8c\" --output json",
      "file": "or-jobs-get-4d7e9f3a-output-json.json"
    },
    {
      "match": "or jobs get 4d7e9f3a-1b6c-5e8f-9d4c-3b2a1f0e9d8c --output json",
      "file": "or-jobs-get-4d7e9f3a-output-json.json"
    },
    {
      "match": "or jobs logs \"4d7e9f3a-1b6c-5e8f-9d4c-3b2a1f0e9d8c\" --level Error --output json",
      "file": "or-jobs-logs-4d7e9f3a-level-error-output-json.json"
    },
    {
      "match": "or jobs logs 4d7e9f3a-1b6c-5e8f-9d4c-3b2a1f0e9d8c --level Error --output json",
      "file": "or-jobs-logs-4d7e9f3a-level-error-output-json.json"
    },
    {
      "match": "or assets list --folder-key 2c5e8f4a-9b3d-4f6c-8e1d-7a2b3c4d5e6f --output json",
      "file": "or-assets-list-folder-key-2c5e8f4a-output-json.json"
    },
    {
      "match": "or assets list --folder-key \"2c5e8f4a-9b3d-4f6c-8e1d-7a2b3c4d5e6f\" --output json",
      "file": "or-assets-list-folder-key-2c5e8f4a-output-json.json"
    },
    {
      "match": "or users list --output json",
      "file": "or-users-list-output-json.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Proxy open-ended docsai queries to the real uip CLI; cache results in _cache/."
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: any uip command not matched returns []. Lets the agent explore beyond the recorded path."
  }
}
