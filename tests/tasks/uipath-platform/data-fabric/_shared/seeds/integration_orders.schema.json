{
  "displayName": "Integration Orders",
  "description": "Seed entity for integration_query_filters brownfield test. Demonstrates the full per-field config surface accepted by `uip df entities create --body`.",
  "fields": [
    {
      "fieldName": "Code",
      "displayName": "Order Code",
      "description": "Unique order identifier, e.g. ORD-001.",
      "type": "STRING",
      "isRequired": true,
      "isUnique": true,
      "lengthLimit": 50
    },
    {
      "fieldName": "Value",
      "displayName": "Order Value",
      "description": "Order amount in tenant base currency.",
      "type": "DECIMAL",
      "isRequired": true,
      "minValue": 0,
      "maxValue": 1000000,
      "decimalPrecision": 2
    },
    {
      "fieldName": "Status",
      "displayName": "Order Status",
      "description": "One of: Pending | Active | Closed.",
      "type": "STRING",
      "isRequired": true,
      "lengthLimit": 20,
      "defaultValue": "Pending"
    }
  ]
}
