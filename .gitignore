# =============================================================================
# Keep team-shared configurations:
#   .claude/settings.json - Hooks, permissions (team settings)
#   .claude/commands/*.md - Slash commands
#   .claude/agents/*.md - Specialized agents
#   .claude/skills/**/*.md - Domain knowledge
#
# Ignore personal/generated artifacts:

# Testing framework artifacts (analysis/evaluation documents)
**/.claude/testing-framework/

# Local overrides (personal settings)
**/.claude/settings.local.json
**/.claude/*.local.json
**/.claude/**/*.local.md
**/.claude/**/*local*

# Claude Code cache and temporary files
**/.claude/cache/
**/.claude/tmp/
**/.claude/.cache/

# Session-specific outputs
**/.claude/outputs/
**/.claude/sessions/

# Personal notes and drafts
**/.claude/drafts/
**/.claude/notes/
**/.claude/**/*.draft.md

# Hook scripts that may contain personal paths
**/.claude/hooks/*.local.*

# Transient session lockfiles
**/.claude/*.lock

# coder_eval test run artifacts
tests/reports/
tests/runs/
tmp/
c/

# Canary .uipx is managed by canary.py — bootstrapped before each run,
# server-side solution deleted and local file removed on teardown.
tests/tasks/uipath-maestro-flow/canary/Canary/Canary.uipx

# macOS Finder metadata
**/.DS_Store

# Git worktrees
.worktrees/
