            <bpmn:sequenceFlow id="flow1" sourceRef="Event_Start" targetRef="Activity_Failing"/>
            <bpmn:sequenceFlow id="flow2" sourceRef="Activity_Failing" targetRef="Event_NormalEnd"/>
