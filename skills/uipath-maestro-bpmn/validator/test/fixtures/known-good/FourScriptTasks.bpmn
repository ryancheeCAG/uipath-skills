      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_flow_start_to_a" bpmnElement="flow_start_to_a">
        <di:waypoint x="196" y="218" />
        <di:waypoint x="246" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_flow_a_to_b" bpmnElement="flow_a_to_b">
