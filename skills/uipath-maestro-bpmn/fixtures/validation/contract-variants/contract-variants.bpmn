<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:uipath="http://uipath.org/schema/bpmn" id="Definitions_ContractVariants" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/contract-variants">
  <bpmn:message id="Message_ExternalSignal" name="ExternalSignal" />
  <bpmn:process id="Process_ContractVariants" name="Contract Variants" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="Var_RequestId" name="requestId" type="string" elementId="Start_Manual" />
        <uipath:inputOutput id="Var_WorkItemId" name="workItemId" type="string" />
        <uipath:output id="Var_Result" name="result" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Binding_AgentName" name="Synthetic Agent" type="process" elementId="Task_StartAgentJob" resource="process" resourceSubType="Agent" resourceKey="synthetic-agent" propertyAttribute="name" />
        <uipath:binding id="Binding_AgentFolderPath" name="Synthetic Agent" type="process" elementId="Task_StartAgentJob" resource="process" resourceSubType="Agent" resourceKey="synthetic-agent" propertyAttribute="folderPath" />
        <uipath:binding id="Binding_EventConnection" name="Synthetic Event Connection" type="connection" elementId="Task_WaitForExternalEvent" resource="SyntheticEvents" resourceSubType="connection" resourceKey="synthetic-event-connection" />
        <uipath:binding id="Binding_EventTrigger" name="Synthetic Event Trigger" type="eventTrigger" elementId="Task_WaitForExternalEvent" resource="SyntheticEvents.ExternalSignal" resourceSubType="eventTrigger" resourceKey="synthetic-event-trigger" />
      </uipath:bindings>
      <uipath:migrationVersion version="5" />
      <uipath:migrationVersion version="11" />
      <uipath:migrationVersion version="11.5" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Manual" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="Entry_ContractVariants" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_AgentJob</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_StartAgentJob" name="Start Agent Job">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.Binding_AgentName" />
            <uipath:input name="folderPath" type="string" value="=bindings.Binding_AgentFolderPath" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"requestId":"=vars.Var_RequestId"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_Result" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_AgentJob</bpmn:incoming>
      <bpmn:outgoing>Flow_AgentJob_To_A2A</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_A2AAgent" name="A2A Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="A2A.AgentExecution" version="v1" />
          <uipath:context />
          <uipath:input name="Prompt" type="string" value="Summarize the synthetic request." />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AgentJob_To_A2A</bpmn:incoming>
      <bpmn:outgoing>Flow_A2A_To_ApiWorkflow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ExecuteApiWorkflow" name="Execute API Workflow">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context />
          <uipath:input name="payload" type="json" target="bodyField"><![CDATA[{"requestId":"=vars.Var_RequestId"}]]></uipath:input>
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_A2A_To_ApiWorkflow</bpmn:incoming>
      <bpmn:outgoing>Flow_ApiWorkflow_To_BusinessRule</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_BusinessRule" name="Evaluate Business Rule">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.BusinessRules" version="v1" />
          <uipath:context />
          <uipath:input name="facts" type="json" target="bodyField"><![CDATA[{"requestId":"=vars.Var_RequestId"}]]></uipath:input>
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ApiWorkflow_To_BusinessRule</bpmn:incoming>
      <bpmn:outgoing>Flow_BusinessRule_To_CreateQueue</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sendTask id="Task_CreateQueueItem" name="Create Queue Item">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.CreateQueueItem" version="v1" />
          <uipath:context />
          <uipath:input name="itemData" type="json" target="bodyField"><![CDATA[{"requestId":"=vars.Var_RequestId"}]]></uipath:input>
          <uipath:output name="QueueItemId" type="string" var="Var_WorkItemId" source="id" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BusinessRule_To_CreateQueue</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateQueue_To_WaitQueue</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_WaitQueueItem" name="Create And Wait For Queue Item">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.CreateAndWaitForQueueItem" version="v1" />
          <uipath:context />
          <uipath:input name="reference" type="string" value="=vars.Var_WorkItemId" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CreateQueue_To_WaitQueue</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitQueue_To_CallAgentic</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Call_AgenticProcess" name="Call Agentic Process">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgenticProcess" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_WaitQueue_To_CallAgentic</bpmn:incoming>
      <bpmn:outgoing>Flow_CallAgentic_To_CallAgenticAsync</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Call_AgenticProcessAsync" name="Call Agentic Process Async">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgenticProcessAsync" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CallAgentic_To_CallAgenticAsync</bpmn:incoming>
      <bpmn:outgoing>Flow_CallAgenticAsync_To_CallCase</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Call_CaseManagement" name="Call Case Management">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartCaseMgmtProcess" version="v1" />
          <uipath:context />
        </uipath:activity>
        <uipath:caseManagement version="v1"><![CDATA[{"mode":"preserve-only","note":"Synthetic case-management payload"}]]></uipath:caseManagement>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CallAgenticAsync_To_CallCase</bpmn:incoming>
      <bpmn:outgoing>Flow_CallCase_To_CallCaseAsync</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Call_CaseManagementAsync" name="Call Case Management Async">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartCaseMgmtProcessAsync" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CallCase_To_CallCaseAsync</bpmn:incoming>
      <bpmn:outgoing>Flow_CallCaseAsync_To_WaitEvent</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:receiveTask id="Task_WaitForExternalEvent" name="Wait For External Event">
      <bpmn:extensionElements>
        <uipath:event version="v1">
          <uipath:type value="Intsvc.WaitForEvent" version="v1" />
          <uipath:context>
            <uipath:input name="connection" type="resource" value="=bindings.Binding_EventConnection" />
            <uipath:input name="trigger" type="resource" value="=bindings.Binding_EventTrigger" />
            <uipath:input name="connectorKey" type="string" value="synthetic-events" />
            <uipath:input name="eventName" type="string" value="external-signal" />
          </uipath:context>
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CallCaseAsync_To_WaitEvent</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitEvent_To_SendMessage</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageDef_ExternalSignal" messageRef="Message_ExternalSignal" />
    </bpmn:receiveTask>
    <bpmn:intermediateThrowEvent id="Event_SendMessage" name="Send Message">
      <bpmn:extensionElements>
        <uipath:event version="v1">
          <uipath:type value="Maestro.SendMessageEvent" version="v1" />
          <uipath:context>
            <uipath:input name="messageName" type="string" value="SyntheticReply" />
            <uipath:input name="payload" type="json"><![CDATA[{"requestId":"=vars.Var_RequestId","result":"=vars.Var_Result"}]]></uipath:input>
          </uipath:context>
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_WaitEvent_To_SendMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_SendMessage_To_CaseScheduler</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageDef_SyntheticReply" />
    </bpmn:intermediateThrowEvent>
    <bpmn:serviceTask id="Task_CasePlanScheduler" name="Case Plan Scheduler">
      <bpmn:extensionElements>
        <uipath:activity version="v1" preservation="draft-only">
          <uipath:type value="Maestro.CasePlanScheduler" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SendMessage_To_CaseScheduler</bpmn:incoming>
      <bpmn:outgoing>Flow_CaseScheduler_To_CaseGuardrails</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CaseManagerGuardrails" name="Case Manager Guardrails">
      <bpmn:extensionElements>
        <uipath:activity version="v1" preservation="preserve-only">
          <uipath:type value="Maestro.CaseManagerGuardrails" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CaseScheduler_To_CaseGuardrails</bpmn:incoming>
      <bpmn:outgoing>Flow_CaseGuardrails_To_CaseRules</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CaseRulesEvaluator" name="Case Rules Evaluator">
      <bpmn:extensionElements>
        <uipath:activity version="v1" preservation="preserve-only">
          <uipath:type value="Maestro.CaseRulesEvaluator" version="v1" />
          <uipath:context />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CaseGuardrails_To_CaseRules</bpmn:incoming>
      <bpmn:outgoing>Flow_CaseRules_To_Script</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_LegacyScript" name="Legacy Script" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v2" />
        <uipath:Activity version="v1" preservation="unsupported"><![CDATA[{"kind":"generic","behavior":"preserve-only"}]]></uipath:Activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CaseRules_To_Script</bpmn:incoming>
      <bpmn:outgoing>Flow_Script_To_End</bpmn:outgoing>
      <bpmn:script><![CDATA[
return { result: "preserved" };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_Done" name="Done">
      <bpmn:incoming>Flow_Script_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_AgentJob" sourceRef="Start_Manual" targetRef="Task_StartAgentJob" />
    <bpmn:sequenceFlow id="Flow_AgentJob_To_A2A" sourceRef="Task_StartAgentJob" targetRef="Task_A2AAgent" />
    <bpmn:sequenceFlow id="Flow_A2A_To_ApiWorkflow" sourceRef="Task_A2AAgent" targetRef="Task_ExecuteApiWorkflow" />
    <bpmn:sequenceFlow id="Flow_ApiWorkflow_To_BusinessRule" sourceRef="Task_ExecuteApiWorkflow" targetRef="Task_BusinessRule" />
    <bpmn:sequenceFlow id="Flow_BusinessRule_To_CreateQueue" sourceRef="Task_BusinessRule" targetRef="Task_CreateQueueItem" />
    <bpmn:sequenceFlow id="Flow_CreateQueue_To_WaitQueue" sourceRef="Task_CreateQueueItem" targetRef="Task_WaitQueueItem" />
    <bpmn:sequenceFlow id="Flow_WaitQueue_To_CallAgentic" sourceRef="Task_WaitQueueItem" targetRef="Call_AgenticProcess" />
    <bpmn:sequenceFlow id="Flow_CallAgentic_To_CallAgenticAsync" sourceRef="Call_AgenticProcess" targetRef="Call_AgenticProcessAsync" />
    <bpmn:sequenceFlow id="Flow_CallAgenticAsync_To_CallCase" sourceRef="Call_AgenticProcessAsync" targetRef="Call_CaseManagement" />
    <bpmn:sequenceFlow id="Flow_CallCase_To_CallCaseAsync" sourceRef="Call_CaseManagement" targetRef="Call_CaseManagementAsync" />
    <bpmn:sequenceFlow id="Flow_CallCaseAsync_To_WaitEvent" sourceRef="Call_CaseManagementAsync" targetRef="Task_WaitForExternalEvent" />
    <bpmn:sequenceFlow id="Flow_WaitEvent_To_SendMessage" sourceRef="Task_WaitForExternalEvent" targetRef="Event_SendMessage" />
    <bpmn:sequenceFlow id="Flow_SendMessage_To_CaseScheduler" sourceRef="Event_SendMessage" targetRef="Task_CasePlanScheduler" />
    <bpmn:sequenceFlow id="Flow_CaseScheduler_To_CaseGuardrails" sourceRef="Task_CasePlanScheduler" targetRef="Task_CaseManagerGuardrails" />
    <bpmn:sequenceFlow id="Flow_CaseGuardrails_To_CaseRules" sourceRef="Task_CaseManagerGuardrails" targetRef="Task_CaseRulesEvaluator" />
    <bpmn:sequenceFlow id="Flow_CaseRules_To_Script" sourceRef="Task_CaseRulesEvaluator" targetRef="Task_LegacyScript" />
    <bpmn:sequenceFlow id="Flow_Script_To_End" sourceRef="Task_LegacyScript" targetRef="End_Done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_ContractVariants">
    <bpmndi:BPMNPlane id="Plane_ContractVariants" bpmnElement="Process_ContractVariants">
      <bpmndi:BPMNShape id="Shape_Start_Manual" bpmnElement="Start_Manual"><dc:Bounds x="80" y="130" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_StartAgentJob" bpmnElement="Task_StartAgentJob"><dc:Bounds x="160" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_A2AAgent" bpmnElement="Task_A2AAgent"><dc:Bounds x="320" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ExecuteApiWorkflow" bpmnElement="Task_ExecuteApiWorkflow"><dc:Bounds x="480" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_BusinessRule" bpmnElement="Task_BusinessRule"><dc:Bounds x="640" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CreateQueueItem" bpmnElement="Task_CreateQueueItem"><dc:Bounds x="800" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_WaitQueueItem" bpmnElement="Task_WaitQueueItem"><dc:Bounds x="960" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_AgenticProcess" bpmnElement="Call_AgenticProcess"><dc:Bounds x="1120" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_AgenticProcessAsync" bpmnElement="Call_AgenticProcessAsync"><dc:Bounds x="1280" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_CaseManagement" bpmnElement="Call_CaseManagement"><dc:Bounds x="1440" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Call_CaseManagementAsync" bpmnElement="Call_CaseManagementAsync"><dc:Bounds x="1600" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_WaitForExternalEvent" bpmnElement="Task_WaitForExternalEvent"><dc:Bounds x="1760" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_SendMessage" bpmnElement="Event_SendMessage"><dc:Bounds x="1922" y="130" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CasePlanScheduler" bpmnElement="Task_CasePlanScheduler"><dc:Bounds x="2000" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CaseManagerGuardrails" bpmnElement="Task_CaseManagerGuardrails"><dc:Bounds x="2160" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CaseRulesEvaluator" bpmnElement="Task_CaseRulesEvaluator"><dc:Bounds x="2320" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_LegacyScript" bpmnElement="Task_LegacyScript"><dc:Bounds x="2480" y="108" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Done" bpmnElement="End_Done"><dc:Bounds x="2640" y="130" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_AgentJob" bpmnElement="Flow_Start_To_AgentJob"><di:waypoint x="116" y="148" /><di:waypoint x="160" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_AgentJob_To_A2A" bpmnElement="Flow_AgentJob_To_A2A"><di:waypoint x="280" y="148" /><di:waypoint x="320" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_A2A_To_ApiWorkflow" bpmnElement="Flow_A2A_To_ApiWorkflow"><di:waypoint x="440" y="148" /><di:waypoint x="480" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ApiWorkflow_To_BusinessRule" bpmnElement="Flow_ApiWorkflow_To_BusinessRule"><di:waypoint x="600" y="148" /><di:waypoint x="640" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_BusinessRule_To_CreateQueue" bpmnElement="Flow_BusinessRule_To_CreateQueue"><di:waypoint x="760" y="148" /><di:waypoint x="800" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CreateQueue_To_WaitQueue" bpmnElement="Flow_CreateQueue_To_WaitQueue"><di:waypoint x="920" y="148" /><di:waypoint x="960" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitQueue_To_CallAgentic" bpmnElement="Flow_WaitQueue_To_CallAgentic"><di:waypoint x="1080" y="148" /><di:waypoint x="1120" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CallAgentic_To_CallAgenticAsync" bpmnElement="Flow_CallAgentic_To_CallAgenticAsync"><di:waypoint x="1240" y="148" /><di:waypoint x="1280" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CallAgenticAsync_To_CallCase" bpmnElement="Flow_CallAgenticAsync_To_CallCase"><di:waypoint x="1400" y="148" /><di:waypoint x="1440" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CallCase_To_CallCaseAsync" bpmnElement="Flow_CallCase_To_CallCaseAsync"><di:waypoint x="1560" y="148" /><di:waypoint x="1600" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CallCaseAsync_To_WaitEvent" bpmnElement="Flow_CallCaseAsync_To_WaitEvent"><di:waypoint x="1720" y="148" /><di:waypoint x="1760" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitEvent_To_SendMessage" bpmnElement="Flow_WaitEvent_To_SendMessage"><di:waypoint x="1880" y="148" /><di:waypoint x="1922" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SendMessage_To_CaseScheduler" bpmnElement="Flow_SendMessage_To_CaseScheduler"><di:waypoint x="1958" y="148" /><di:waypoint x="2000" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CaseScheduler_To_CaseGuardrails" bpmnElement="Flow_CaseScheduler_To_CaseGuardrails"><di:waypoint x="2120" y="148" /><di:waypoint x="2160" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CaseGuardrails_To_CaseRules" bpmnElement="Flow_CaseGuardrails_To_CaseRules"><di:waypoint x="2280" y="148" /><di:waypoint x="2320" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CaseRules_To_Script" bpmnElement="Flow_CaseRules_To_Script"><di:waypoint x="2440" y="148" /><di:waypoint x="2480" y="148" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Script_To_End" bpmnElement="Flow_Script_To_End"><di:waypoint x="2600" y="148" /><di:waypoint x="2640" y="148" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
