<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:uipath="http://uipath.org/schema/bpmn" id="Definitions_WrapperFamilyContract" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/wrapper-family-contract">
  <bpmn:process id="Process_WrapperFamilyContract" name="Wrapper Family Contract" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="Var_Request" name="request" type="json" elementId="Start_Manual"><![CDATA[{"type":"object","properties":{"caseId":{"type":"string"}}}]]></uipath:input>
        <uipath:inputOutput id="Var_AgentResult" name="agentResult" type="json" />
        <uipath:inputOutput id="Var_ApiResult" name="apiResult" type="json" />
        <uipath:inputOutput id="Var_RuleResult" name="ruleResult" type="string" />
        <uipath:inputOutput id="Var_QueueState" name="queueState" type="string" />
        <uipath:output id="Var_FinalStatus" name="finalStatus" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Binding_AgentDefinition" name="Synthetic Agent" type="agent" elementId="Task_RunAgent" resource="SyntheticAgent" resourceSubType="agent" resourceKey="synthetic-agent" />
        <uipath:binding id="Binding_ApiWorkflow" name="Synthetic API Workflow" type="process" elementId="Task_RunApiWorkflow" resource="SyntheticApiWorkflow" resourceSubType="apiWorkflow" resourceKey="synthetic-api-workflow" />
        <uipath:binding id="Binding_BusinessRule" name="Synthetic Business Rule" type="process" elementId="Task_RunBusinessRule" resource="SyntheticBusinessRule" resourceSubType="businessRules" resourceKey="synthetic-business-rule" />
        <uipath:binding id="Binding_Queue" name="Synthetic Queue" type="queue" elementId="Task_QueueAndWait" resource="SyntheticQueue" resourceSubType="queue" resourceKey="synthetic-queue" />
        <uipath:binding id="Binding_CaseProcess" name="Synthetic Case Process" type="process" elementId="Task_StartCaseProcess" resource="SyntheticCaseProcess" resourceSubType="caseManagement" resourceKey="synthetic-case-process" />
        <uipath:binding id="Binding_WaitConnection" name="Synthetic Connector Connection" type="connection" elementId="Task_WaitForConnectorEvent" resource="SyntheticConnector" resourceSubType="connection" resourceKey="synthetic-connector-connection" />
        <uipath:binding id="Binding_WaitTrigger" name="Synthetic Connector Trigger" type="eventTrigger" elementId="Task_WaitForConnectorEvent" resource="SyntheticConnector.CaseUpdated" resourceSubType="eventTrigger" resourceKey="synthetic-connector-trigger" />
      </uipath:bindings>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Manual" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="Entry_WrapperFamilyContract" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_Agent</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_RunAgent" name="Run Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="A2A.AgentExecution" version="v1" />
          <uipath:context>
            <uipath:input name="agent" type="resource" value="=bindings.Binding_AgentDefinition" />
          </uipath:context>
          <uipath:input name="body" type="json" target="bodyField"><![CDATA[{"request":"=request"}]]></uipath:input>
          <uipath:output name="response" type="json" var="agentResult" source="response" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Agent</bpmn:incoming>
      <bpmn:outgoing>Flow_Agent_To_Api</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RunApiWorkflow" name="Run API Workflow">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="process" type="resource" value="=bindings.Binding_ApiWorkflow" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"agentResult":"=agentResult"}]]></uipath:input>
          <uipath:output name="JobResult" type="json" var="apiResult" source="result" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Agent_To_Api</bpmn:incoming>
      <bpmn:outgoing>Flow_Api_To_BusinessRule</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_RunBusinessRule" name="Run Business Rule">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.BusinessRules" version="v1" />
          <uipath:context>
            <uipath:input name="process" type="resource" value="=bindings.Binding_BusinessRule" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"apiResult":"=apiResult"}]]></uipath:input>
          <uipath:output name="RuleDecision" type="string" var="ruleResult" source="decision" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Api_To_BusinessRule</bpmn:incoming>
      <bpmn:outgoing>Flow_BusinessRule_To_Queue</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="Task_QueueAndWait" name="Queue And Wait">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.CreateAndWaitForQueueItem" version="v1" />
          <uipath:context>
            <uipath:input name="queue" type="resource" value="=bindings.Binding_Queue" />
          </uipath:context>
          <uipath:input name="ItemData" type="json" target="bodyField"><![CDATA[{"ruleResult":"=ruleResult"}]]></uipath:input>
          <uipath:output name="QueueStatus" type="string" var="queueState" source="status" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BusinessRule_To_Queue</bpmn:incoming>
      <bpmn:outgoing>Flow_Queue_To_Case</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Task_StartCaseProcess" name="Start Case Process">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartCaseMgmtProcess" version="v1" />
          <uipath:context>
            <uipath:input name="process" type="resource" value="=bindings.Binding_CaseProcess" />
          </uipath:context>
          <uipath:input name="caseManagerInput" type="json" target="bodyField"><![CDATA[{"queueState":"=queueState"}]]></uipath:input>
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Queue_To_Case</bpmn:incoming>
      <bpmn:outgoing>Flow_Case_To_Wait</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:receiveTask id="Task_WaitForConnectorEvent" name="Wait For Connector Event">
      <bpmn:extensionElements>
        <uipath:event version="v1">
          <uipath:type value="Intsvc.WaitForEvent" version="v1" />
          <uipath:context>
            <uipath:input name="connection" type="resource" value="=bindings.Binding_WaitConnection" />
            <uipath:input name="trigger" type="resource" value="=bindings.Binding_WaitTrigger" />
            <uipath:input name="connectorKey" type="string" value="synthetic-connector" />
            <uipath:input name="eventName" type="string" value="CaseUpdated" />
          </uipath:context>
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Case_To_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Wait_To_End</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="End_Done" name="Done">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:output name="finalStatus" type="string" var="finalStatus" source="done" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Wait_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Agent" sourceRef="Start_Manual" targetRef="Task_RunAgent" />
    <bpmn:sequenceFlow id="Flow_Agent_To_Api" sourceRef="Task_RunAgent" targetRef="Task_RunApiWorkflow" />
    <bpmn:sequenceFlow id="Flow_Api_To_BusinessRule" sourceRef="Task_RunApiWorkflow" targetRef="Task_RunBusinessRule" />
    <bpmn:sequenceFlow id="Flow_BusinessRule_To_Queue" sourceRef="Task_RunBusinessRule" targetRef="Task_QueueAndWait" />
    <bpmn:sequenceFlow id="Flow_Queue_To_Case" sourceRef="Task_QueueAndWait" targetRef="Task_StartCaseProcess" />
    <bpmn:sequenceFlow id="Flow_Case_To_Wait" sourceRef="Task_StartCaseProcess" targetRef="Task_WaitForConnectorEvent" />
    <bpmn:sequenceFlow id="Flow_Wait_To_End" sourceRef="Task_WaitForConnectorEvent" targetRef="End_Done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_WrapperFamilyContract">
    <bpmndi:BPMNPlane id="Plane_WrapperFamilyContract" bpmnElement="Process_WrapperFamilyContract">
      <bpmndi:BPMNShape id="Shape_Start_Manual" bpmnElement="Start_Manual"><dc:Bounds x="80" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RunAgent" bpmnElement="Task_RunAgent"><dc:Bounds x="170" y="138" width="130" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RunApiWorkflow" bpmnElement="Task_RunApiWorkflow"><dc:Bounds x="350" y="138" width="130" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RunBusinessRule" bpmnElement="Task_RunBusinessRule"><dc:Bounds x="530" y="138" width="130" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_QueueAndWait" bpmnElement="Task_QueueAndWait"><dc:Bounds x="710" y="138" width="130" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_StartCaseProcess" bpmnElement="Task_StartCaseProcess"><dc:Bounds x="890" y="138" width="130" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_WaitForConnectorEvent" bpmnElement="Task_WaitForConnectorEvent"><dc:Bounds x="1070" y="150" width="100" height="56" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Done" bpmnElement="End_Done"><dc:Bounds x="1230" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_Agent" bpmnElement="Flow_Start_To_Agent"><di:waypoint x="116" y="178" /><di:waypoint x="170" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Agent_To_Api" bpmnElement="Flow_Agent_To_Api"><di:waypoint x="300" y="178" /><di:waypoint x="350" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Api_To_BusinessRule" bpmnElement="Flow_Api_To_BusinessRule"><di:waypoint x="480" y="178" /><di:waypoint x="530" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_BusinessRule_To_Queue" bpmnElement="Flow_BusinessRule_To_Queue"><di:waypoint x="660" y="178" /><di:waypoint x="710" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Queue_To_Case" bpmnElement="Flow_Queue_To_Case"><di:waypoint x="840" y="178" /><di:waypoint x="890" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Case_To_Wait" bpmnElement="Flow_Case_To_Wait"><di:waypoint x="1020" y="178" /><di:waypoint x="1070" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Wait_To_End" bpmnElement="Flow_Wait_To_End"><di:waypoint x="1170" y="178" /><di:waypoint x="1230" y="178" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
