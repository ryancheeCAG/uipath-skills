# Public SPA config (no secret — auth is OAuth PKCE with a non-confidential client ID).
# The build script writes these to .env.local (dev) AND .env.production. The deploy step
# renames .env.local away (to strip any dev PAT) but .env.production survives, so the
# built bundle keeps its SDK config. Copy to .env.local for manual local dev.

# Cloud URL (Data.BaseUrl from uip login status):
#   alpha:   https://alpha.uipath.com
#   staging: https://staging.uipath.com
#   prod:    https://cloud.uipath.com
VITE_UIPATH_CLOUD_URL=https://cloud.uipath.com

# API base URL ("api." subdomain) — used for TS SDK calls:
#   alpha:   https://alpha.api.uipath.com
#   staging: https://staging.api.uipath.com
#   prod:    https://api.uipath.com
VITE_UIPATH_BASE_URL=https://api.uipath.com

VITE_UIPATH_ORG_NAME=
VITE_UIPATH_TENANT_NAME=
VITE_UIPATH_CLIENT_ID=
