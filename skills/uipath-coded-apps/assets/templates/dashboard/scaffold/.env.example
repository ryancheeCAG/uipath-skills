# Base URL — auto-detected from uip login session at scaffold time:
#   alpha:   https://alpha.api.uipath.com
#   staging: https://staging.api.uipath.com
#   prod:    https://api.uipath.com
VITE_UIPATH_BASE_URL=https://api.uipath.com
VITE_UIPATH_ORG_NAME=
VITE_UIPATH_TENANT_NAME=
VITE_INSIGHTS_TENANT_ID=

# Dev/preview only — read from ~/.uipath/.auth by the skill at scaffold time.
# Leave blank for production builds (failBuildIfPatSet plugin blocks PAT in bundles).
VITE_UIPATH_PAT=
