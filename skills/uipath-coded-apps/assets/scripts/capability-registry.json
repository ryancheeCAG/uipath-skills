{
  "t1": {
    "agent-errors": {
      "aliases": ["agent errors", "error count", "errors over time", "agent failures", "error rate trend", "error spikes", "which agents are failing"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "AgentsInsights",
      "sdkMethod": "getErrors",
      "template": "line-chart",
      "responseType": "AgentErrorsResponse",
      "defaults": {
        "title": "Agent Error Rate",
        "description": "Daily error counts — spot spikes early",
        "icon": "AlertTriangle",
        "xKey": "date",
        "yKey": "value",
        "deltaDir": "down-good",
        "deltaText": "errors today",
        "dataSelector": "data?.data ?? []",
        "valueExpression": "String((data?.data ?? []).reduce((s, d) => s + (d.value ?? 0), 0))"
      }
    },
    "invocation-volume": {
      "aliases": ["invocation volume", "total runs", "agent runs", "invocations", "run volume", "execution volume", "agu consumption", "consumption timeline"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "AgentsInsights",
      "sdkMethod": "getConsumptionTimeline",
      "template": "area-chart",
      "responseType": "ConsumptionTimelineResponse",
      "defaults": {
        "title": "Invocation Volume",
        "description": "Agent AGU consumption over time",
        "icon": "Activity",
        "xKey": "timeSlice",
        "yKey": "aguConsumption",
        "deltaDir": "up-good",
        "deltaText": "AGU today",
        "dataSelector": "data?.data ?? []",
        "valueExpression": "String(((data?.data ?? []).reduce((s, d) => s + (d.aguConsumption ?? 0), 0)).toFixed(1))"
      }
    },
    "top-failing-agents": {
      "aliases": ["top failing agents", "most errors by agent", "agent leaderboard errors", "which agents fail most"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "AgentsInsights",
      "sdkMethod": "getTopErroredAgents",
      "template": "ranked-table",
      "responseType": "TopErroredAgentsResponse",
      "defaults": {
        "title": "Top Failing Agents",
        "description": "Agents with the most errors",
        "icon": "AlertOctagon",
        "dataSelector": "data?.data ?? []",
        "columns": "[{key:\"name\",label:\"Agent\"},{key:\"count\",label:\"Errors\",align:\"right\" as const}]",
        "deltaDir": "neutral",
        "deltaText": ""
      }
    },
    "active-agents-kpi": {
      "aliases": ["active agents", "active agent count", "how many agents", "agent count", "agents running"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "AgentsInsights",
      "sdkMethod": "getAgents",
      "template": "kpi-card",
      "responseType": "AgentsResponse",
      "defaults": {
        "title": "Active Agents",
        "description": "Agents with at least one run",
        "icon": "Bot",
        "valueExpression": "String(data?.data?.agents?.length ?? 0)",
        "dataSelector": "data?.data?.agents ?? []",
        "deltaDir": "up-good",
        "deltaText": "active agents"
      }
    },
    "agent-latency": {
      "aliases": ["agent latency", "p95 latency", "response time", "execution time", "latency trend"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "AgentsInsights",
      "sdkMethod": "getLatencyTimeline",
      "template": "multi-line-chart",
      "responseType": "LatencyTimelineResponse",
      "defaults": {
        "title": "Agent Latency",
        "description": "P50 and P95 execution time",
        "icon": "Timer",
        "xKey": "date",
        "yKey": "P95",
        "deltaDir": "down-good",
        "deltaText": "ms P95",
        "dataSelector": "data?.data ?? []",
        "series": "[{key:\"P50\",color:\"hsl(var(--chart-1))\",label:\"P50 ms\"},{key:\"P95\",color:\"hsl(var(--chart-2))\",label:\"P95 ms\"}]",
        "pivotExpression": "rawData.reduce((acc: Record<string, unknown>[], row: any) => { const existing = acc.find((r: any) => r.date === row.date); if (existing) { existing[row.name] = row.value; } else { acc.push({ date: row.date, [row.name]: row.value }); } return acc; }, [])"
      }
    },
    "job-failures": {
      "aliases": ["job failures", "job failure rate", "rpa failures", "process failures", "failed jobs"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "JobsInsights",
      "sdkMethod": "getTopFailures",
      "template": "ranked-table",
      "responseType": "TopFailuresResponse",
      "defaults": {
        "title": "Top Job Failures",
        "description": "Processes with the most failures",
        "icon": "XCircle",
        "dataSelector": "data?.data ?? []",
        "columns": "[{key:\"processName\",label:\"Process\"},{key:\"failureCount\",label:\"Failures\",align:\"right\" as const}]",
        "deltaDir": "down-good",
        "deltaText": "failures today"
      }
    },
    "job-completion-trend": {
      "aliases": ["job completions", "completed jobs", "jobs over time", "job volume", "rpa throughput"],
      "sdkImport": "@uipath/uipath-typescript/insights",
      "sdkService": "JobsInsights",
      "sdkMethod": "getCompletedTimeline",
      "template": "area-chart",
      "responseType": "CompletedTimelineResponse",
      "defaults": {
        "title": "Job Completions",
        "description": "Jobs completed per day",
        "icon": "CheckCircle",
        "xKey": "date",
        "yKey": "count",
        "deltaDir": "up-good",
        "deltaText": "completions today",
        "dataSelector": "data?.data ?? []"
      }
    }
  },
  "t2": {
    "jobs-duration-threshold": {
      "aliases": ["long running jobs", "jobs over duration", "slow jobs", "jobs running longer than"],
      "service": "jobs",
      "sdkImport": "@uipath/uipath-typescript/jobs",
      "sdkService": "Jobs",
      "method": "getAll",
      "filterField": "duration",
      "filterType": "number",
      "sortField": "duration",
      "defaultDisplayAs": "data-table",
      "defaults": {
        "title": "Long-Running Jobs",
        "description": "Jobs exceeding duration threshold",
        "icon": "Clock",
        "columns": "[{key:\"name\",label:\"Process\"},{key:\"state\",label:\"State\"},{key:\"duration\",label:\"Duration\",align:\"right\" as const}]",
        "dataSelector": "(data as any)?.items ?? []",
        "deltaDir": "neutral",
        "deltaText": ""
      }
    },
    "jobs-by-state": {
      "aliases": ["faulted jobs", "running jobs", "stopped jobs", "successful jobs", "jobs in state", "jobs by state", "failed jobs", "active jobs"],
      "service": "jobs",
      "sdkImport": "@uipath/uipath-typescript/jobs",
      "sdkService": "Jobs",
      "method": "getAll",
      "filterField": "state",
      "filterType": "string",
      "sortField": "createdTime",
      "sortDir": "desc",
      "defaultDisplayAs": "data-table",
      "defaults": {
        "title": "Jobs by State",
        "description": "Jobs filtered by execution state",
        "icon": "Play",
        "columns": "[{key:\"processName\",label:\"Process\"},{key:\"state\",label:\"State\"},{key:\"createdTime\",label:\"Started\"}]",
        "deltaDir": "neutral",
        "deltaText": "",
        "dataSelector": "(data as any)?.items ?? []"
      }
    },
    "tasks-by-status": {
      "aliases": ["pending tasks", "completed tasks", "open tasks", "tasks by status", "action center tasks", "human tasks", "unassigned tasks"],
      "service": "tasks",
      "sdkImport": "@uipath/uipath-typescript/tasks",
      "sdkService": "Tasks",
      "method": "getAll",
      "filterField": "status",
      "filterType": "string",
      "sortField": "createdTime",
      "sortDir": "desc",
      "defaultDisplayAs": "data-table",
      "defaults": {
        "title": "Tasks by Status",
        "description": "Action Center tasks filtered by status",
        "icon": "CheckSquare",
        "columns": "[{key:\"title\",label:\"Task\"},{key:\"status\",label:\"Status\"},{key:\"priority\",label:\"Priority\"},{key:\"createdTime\",label:\"Created\"}]",
        "deltaDir": "neutral",
        "deltaText": "",
        "dataSelector": "(data as any)?.items ?? []"
      }
    },
    "cases-running-above": {
      "aliases": ["cases with many running", "high volume processes", "running case count above", "active cases above", "maestro cases", "process instances above"],
      "service": "cases",
      "sdkImport": "@uipath/uipath-typescript/cases",
      "sdkService": "Cases",
      "method": "getAll",
      "filterField": "runningCount",
      "filterType": "number",
      "sortField": "runningCount",
      "sortDir": "desc",
      "defaultDisplayAs": "ranked-table",
      "defaults": {
        "title": "High-Volume Cases",
        "description": "Processes with running case count above threshold",
        "icon": "GitBranch",
        "columns": "[{key:\"processKey\",label:\"Process\"},{key:\"runningCount\",label:\"Running\",align:\"right\" as const},{key:\"completedCount\",label:\"Completed\",align:\"right\" as const}]",
        "deltaDir": "neutral",
        "deltaText": "",
        "dataSelector": "(data as any) ?? []"
      }
    }
  },
  "hardRefuse": [
    { "pattern": "cost.*dollar|dollar.*cost|\\$.*agent|agent.*\\$", "reason": "The platform tracks AGU units, not currency.", "alternative": "AGU consumption chart (metric: invocation-volume)" },
    { "pattern": "cpu|memory per agent|per.agent memory", "reason": "Per-agent CPU/memory is not exposed by any API.", "alternative": "Fleet-level latency (metric: agent-latency)" },
    { "pattern": "who triggered|triggered by|user.*job|job.*user", "reason": "Job records carry no end-user identity.", "alternative": "Job counts by process name (metric: job-completion-trend)" },
    { "pattern": "cross.tenant|multi.tenant|compare.*tenant", "reason": "Dashboards are scoped to one tenant.", "alternative": "Multi-widget single-tenant view" },
    { "pattern": "sla.*breach|breach.*sla", "reason": "Raw counts only — no SLA metadata in any API.", "alternative": "Success rate % (computable from job-completion-trend)" },
    { "pattern": "error.*message|stack.*trace|exception.*text", "reason": "No aggregation endpoint for error text or stack traces.", "alternative": "Error count by type (metric: agent-errors)" },
    { "pattern": "governance.*policy.*summary|policy.*summary.*governance|getPolicySummary", "reason": "governance.getPolicySummary requires a specific policy UUID that must be supplied by the user.", "alternative": "Ask the user which policy UUID to report on, then classify as T3-Insights with method: getPolicySummary and the UUID injected into the request body." },
    { "pattern": "queue.*failure.*threshold|queues.*failing|high.failure.*queue", "reason": "QueueGetResponse does not include a failure count field. SDK fields are: id, name, maxRetries, acceptsRejectedItems only.", "alternative": "T3-Insights: use namespace: 'jobs', method: 'getTopFailures' to see processes with most failures, or request queue metrics via T3-SDK if your tenant has queue analytics enabled." }
  ]
}
